def recalculate_participant_fields(db, participant):
    current_month = datetime.now().strftime("%Y-%m")
    
    # 1. total_paid = сумма всех доходов
    total_paid = sum всех доходов
    
    # 2. Считаем сколько должен заплатить за всё время
    amount_required = 0
    
    # Получаем историю членства в группах
    memberships = db.query(MembershipHistory).filter(
        MembershipHistory.participant_id == participant.id
    ).all()
    
    for membership in memberships:
        # Для каждого периода в группе считаем месяцы
        group = membership.group
        start = membership.joined_at  # "2026-03"
        end = membership.left_at or current_month  # "2026-06" или сейчас
        
        months_in_group = сколько_месяцев_между(start, end)
        amount_required += months_in_group * group.monthly_fee
    
    # 3. Баланс = внёс - должен
    participant.balance = total_paid - amount_required
    
    # 4. paid_until_month = до какого месяца хватило денег
    # (сложная логика с учётом смены групп)
